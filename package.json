{
  "name": "sufficit-vscode-symposium",
  "displayName": "Symposium",
  "description": "Symposium (συμπόσιον) — host and conduct dialogue sessions with multiple AI agents (Claude Code, Codex CLI, GitHub Copilot CLI) side by side inside VS Code.",
  "version": "0.64.0",
  "publisher": "sufficit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sufficit/sufficit-vscode-symposium"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "symposium",
          "title": "Symposium",
          "icon": "media/symposium.svg"
        }
      ]
    },
    "views": {
      "symposium": [
        {
          "id": "symposium.chat",
          "type": "webview",
          "name": "Chat",
          "icon": "media/symposium.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "symposium.newSession",
        "title": "Symposium: New Session",
        "icon": "$(add)"
      },
      {
        "command": "symposium.openSession",
        "title": "Symposium: Open Session"
      },
      {
        "command": "symposium.openSessionInEditor",
        "title": "Open Session in Editor",
        "icon": "$(window)"
      },
      {
        "command": "symposium.followSession",
        "title": "Watch Live (read-only)",
        "icon": "$(eye)"
      },
      {
        "command": "symposium.newTerminalSession",
        "title": "Symposium: New Terminal Session",
        "icon": "$(terminal)"
      },
      {
        "command": "symposium.resumeInTerminal",
        "title": "Resume in Terminal (full control)",
        "icon": "$(terminal)"
      },
      {
        "command": "symposium.newPersistentSession",
        "title": "Symposium: New Persistent Session (tmux, survives close)",
        "icon": "$(pinned)"
      },
      {
        "command": "symposium.reattachPersistent",
        "title": "Symposium: Reattach Persistent Session",
        "icon": "$(plug)"
      },
      {
        "command": "symposium.renameSession",
        "title": "Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "symposium.archiveSession",
        "title": "Archive Session",
        "icon": "$(archive)"
      },
      {
        "command": "symposium.unarchiveSession",
        "title": "Unarchive Session",
        "icon": "$(history)"
      },
      {
        "command": "symposium.deleteSession",
        "title": "Delete Session (permanent)",
        "icon": "$(trash)"
      },
      {
        "command": "symposium.refreshSessions",
        "title": "Symposium: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "symposium.openSettings",
        "title": "Symposium: Settings",
        "icon": "$(gear)"
      },
      {
        "command": "symposium.reload",
        "title": "Symposium: Reload Window (apply latest build)",
        "icon": "$(debug-restart)"
      },
      {
        "command": "symposium.editAdapters",
        "title": "Symposium: Edit Adapters (JSON)",
        "icon": "$(json)"
      },
      {
        "command": "symposium.openConfig",
        "title": "Symposium: Configuration",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "symposium.newSession",
          "when": "view == symposium.chat",
          "group": "navigation@1"
        },
        {
          "command": "symposium.newTerminalSession",
          "when": "view == symposium.chat",
          "group": "navigation@2"
        },
        {
          "command": "symposium.refreshSessions",
          "when": "view == symposium.chat",
          "group": "navigation@3"
        },
        {
          "command": "symposium.reattachPersistent",
          "when": "view == symposium.chat",
          "group": "navigation@4"
        },
        {
          "command": "symposium.openConfig",
          "when": "view == symposium.chat",
          "group": "navigation@5"
        },
        {
          "command": "symposium.openSettings",
          "when": "view == symposium.chat",
          "group": "navigation@6"
        },
        {
          "command": "symposium.editAdapters",
          "when": "view == symposium.chat",
          "group": "navigation@6"
        },
        {
          "command": "symposium.reload",
          "when": "view == symposium.chat",
          "group": "navigation@9"
        }
      ]
    },
    "configuration": {
      "title": "Symposium",
      "properties": {
        "symposium.root": {
          "type": "string",
          "default": "",
          "description": "Local root for vendor-neutral agent knowledge (agents/skills/tools/instructions, sync state). Empty uses ~/.symposium."
        },
        "symposium.claude.executable": {
          "type": "string",
          "default": "claude",
          "description": "Path to the Claude Code CLI executable."
        },
        "symposium.claude.model": {
          "type": "string",
          "default": "",
          "description": "Model passed to claude --model. Empty uses the CLI default."
        },
        "symposium.claude.permissionMode": {
          "type": "string",
          "enum": [
            "default",
            "acceptEdits",
            "bypassPermissions",
            "plan"
          ],
          "default": "default",
          "description": "Permission mode passed to claude --permission-mode."
        },
        "symposium.claude.env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "description": "Extra environment variables for the Claude CLI process (e.g. ANTHROPIC_BASE_URL, ANTHROPIC_AUTH_TOKEN for a gateway)."
        },
        "symposium.claude.reasoning": {
          "type": "string",
          "enum": [
            "default",
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ],
          "default": "default",
          "description": "Default reasoning/thinking effort for Claude terminal sessions (claude --effort). 'default' omits the flag."
        },
        "symposium.codex.executable": {
          "type": "string",
          "default": "codex",
          "description": "Path to the Codex CLI executable."
        },
        "symposium.codex.model": {
          "type": "string",
          "default": "",
          "description": "Model passed to codex exec --model. Empty uses the CLI default."
        },
        "symposium.codex.reasoning": {
          "type": "string",
          "enum": [
            "default",
            "minimal",
            "low",
            "medium",
            "high"
          ],
          "default": "default",
          "description": "Default reasoning effort for Codex terminal sessions (codex -c model_reasoning_effort). 'default' omits it."
        },
        "symposium.copilot.executable": {
          "type": "string",
          "default": "copilot",
          "description": "Path to the GitHub Copilot CLI executable."
        },
        "symposium.copilot.model": {
          "type": "string",
          "default": "",
          "description": "Model passed to copilot --model. Empty uses the CLI default."
        },
        "symposium.copilot.reasoning": {
          "type": "string",
          "enum": [
            "default",
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "default": "default",
          "description": "Default reasoning effort for Copilot terminal sessions (copilot --reasoning-effort). 'default' omits it."
        },
        "symposium.adapters": {
          "type": "array",
          "default": [],
          "markdownDescription": "Extra OpenAI-compatible adapters (e.g. multiple Sufficit AI gateways). Each entry: `{ name, baseUrl, headers, apiKey, model, models }`. `id` is auto-generated (GUID) on save if omitted — keeps sessions stable when you rename. Leave `models` empty to auto-discover from `GET <baseUrl>/models`. Edit via 'Symposium: Edit Adapters (JSON)'.",
          "items": {
            "type": "object",
            "required": [
              "baseUrl"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Stable backend key. Auto-generated (GUID, no hyphens) on save if omitted; set manually in any format if you prefer."
              },
              "name": {
                "type": "string",
                "description": "Display name shown in the UI."
              },
              "api": {
                "type": "string",
                "enum": [
                  "chat",
                  "responses"
                ],
                "default": "chat",
                "description": "Request type: 'chat' (POST <baseUrl>/chat/completions) or 'responses' (POST <baseUrl>/responses)."
              },
              "baseUrl": {
                "type": "string",
                "description": "OpenAI-compatible base URL."
              },
              "apiKey": {
                "type": "string",
                "description": "Sent as Authorization: Bearer <key> when no Authorization header is set."
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Custom HTTP headers."
              },
              "model": {
                "type": "string",
                "description": "Default model id."
              },
              "models": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Model ids; empty = auto-discover from /models."
              }
            }
          }
        },
        "symposium.openai.api": {
          "type": "string",
          "enum": [
            "chat",
            "responses"
          ],
          "default": "chat",
          "description": "Request type for the built-in OpenAI adapter: 'chat' (/chat/completions) or 'responses' (/responses)."
        },
        "symposium.openai.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL of an OpenAI-compatible API (e.g. the Sufficit AI gateway)."
        },
        "symposium.openai.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key sent as 'Authorization: Bearer <key>' when no Authorization header is set in symposium.openai.headers."
        },
        "symposium.openai.headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "description": "Custom HTTP headers for the OpenAI-compatible endpoint (e.g. Authorization, x-api-key, gateway routing for Sufficit AI)."
        },
        "symposium.openai.model": {
          "type": "string",
          "default": "",
          "description": "Default model id. Empty uses the first of symposium.openai.models."
        },
        "symposium.openai.models": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Model ids offered in the picker (the Sufficit AI catalog)."
        },
        "symposium.openai.reasoning": {
          "type": "string",
          "enum": [
            "default",
            "minimal",
            "low",
            "medium",
            "high"
          ],
          "default": "default",
          "description": "Default reasoning_effort for models that support it. 'default' omits the parameter."
        },
        "symposium.chat.openIn": {
          "type": "string",
          "enum": [
            "editor",
            "sidebar"
          ],
          "default": "editor",
          "description": "Where sessions open: as a full editor panel (default, like the built-in chat sessions viewer) or in the Symposium sidebar Chat view."
        },
        "symposium.chat.sessionsSide": {
          "type": "string",
          "enum": [
            "auto",
            "left",
            "right"
          ],
          "default": "auto",
          "description": "Side of the sessions list inside the chat surface. 'auto' follows the dock side (sessions on the outer edge: right when docked right, left when docked left)."
        },
        "symposium.chat.whenBusy": {
          "type": "string",
          "enum": [
            "queue",
            "steer"
          ],
          "enumDescriptions": [
            "Queue the message and send it after the current turn (FIFO).",
            "Interrupt the running turn and send immediately."
          ],
          "default": "queue",
          "description": "What sending does WHILE a turn is running. When the agent is idle it always sends immediately, so this only applies when it's busy. Overridable per message with the dropdown next to the send button."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.100.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0"
  }
}
