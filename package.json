{
  "name": "sufficit-vscode-symposium",
  "displayName": "Symposium",
  "description": "Symposium (συμπόσιον) — host and conduct dialogue sessions with multiple AI agents (Claude Code, Codex CLI, GitHub Copilot CLI) side by side inside VS Code.",
  "version": "0.42.0",
  "publisher": "sufficit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sufficit/sufficit-vscode-symposium"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "symposium",
          "title": "Symposium",
          "icon": "media/symposium.svg"
        }
      ]
    },
    "views": {
      "symposium": [
        {
          "id": "symposium.chat",
          "type": "webview",
          "name": "Chat",
          "icon": "media/symposium.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "symposium.newSession",
        "title": "Symposium: New Session",
        "icon": "$(add)"
      },
      {
        "command": "symposium.openSession",
        "title": "Symposium: Open Session"
      },
      {
        "command": "symposium.openSessionInEditor",
        "title": "Open Session in Editor",
        "icon": "$(window)"
      },
      {
        "command": "symposium.followSession",
        "title": "Watch Live (read-only)",
        "icon": "$(eye)"
      },
      {
        "command": "symposium.newTerminalSession",
        "title": "Symposium: New Terminal Session",
        "icon": "$(terminal)"
      },
      {
        "command": "symposium.resumeInTerminal",
        "title": "Resume in Terminal (full control)",
        "icon": "$(terminal)"
      },
      {
        "command": "symposium.newPersistentSession",
        "title": "Symposium: New Persistent Session (tmux, survives close)",
        "icon": "$(pinned)"
      },
      {
        "command": "symposium.reattachPersistent",
        "title": "Symposium: Reattach Persistent Session",
        "icon": "$(plug)"
      },
      {
        "command": "symposium.renameSession",
        "title": "Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "symposium.archiveSession",
        "title": "Archive Session",
        "icon": "$(archive)"
      },
      {
        "command": "symposium.unarchiveSession",
        "title": "Unarchive Session",
        "icon": "$(history)"
      },
      {
        "command": "symposium.deleteSession",
        "title": "Delete Session (permanent)",
        "icon": "$(trash)"
      },
      {
        "command": "symposium.refreshSessions",
        "title": "Symposium: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "symposium.openSettings",
        "title": "Symposium: Settings",
        "icon": "$(gear)"
      },
      {
        "command": "symposium.reload",
        "title": "Symposium: Reload Window (apply latest build)",
        "icon": "$(debug-restart)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "symposium.newSession",
          "when": "view == symposium.chat",
          "group": "navigation@1"
        },
        {
          "command": "symposium.newTerminalSession",
          "when": "view == symposium.chat",
          "group": "navigation@2"
        },
        {
          "command": "symposium.refreshSessions",
          "when": "view == symposium.chat",
          "group": "navigation@3"
        },
        {
          "command": "symposium.reattachPersistent",
          "when": "view == symposium.chat",
          "group": "navigation@4"
        },
        {
          "command": "symposium.openSettings",
          "when": "view == symposium.chat",
          "group": "navigation@5"
        },
        {
          "command": "symposium.reload",
          "when": "view == symposium.chat",
          "group": "navigation@9"
        }
      ]
    },
    "configuration": {
      "title": "Symposium",
      "properties": {
        "symposium.claude.executable": {
          "type": "string",
          "default": "claude",
          "description": "Path to the Claude Code CLI executable."
        },
        "symposium.claude.model": {
          "type": "string",
          "default": "",
          "description": "Model passed to claude --model. Empty uses the CLI default."
        },
        "symposium.claude.permissionMode": {
          "type": "string",
          "enum": [
            "default",
            "acceptEdits",
            "bypassPermissions",
            "plan"
          ],
          "default": "default",
          "description": "Permission mode passed to claude --permission-mode."
        },
        "symposium.claude.env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "description": "Extra environment variables for the Claude CLI process (e.g. ANTHROPIC_BASE_URL, ANTHROPIC_AUTH_TOKEN for a gateway)."
        },
        "symposium.claude.reasoning": {
          "type": "string",
          "enum": [
            "default",
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ],
          "default": "default",
          "description": "Default reasoning/thinking effort for Claude terminal sessions (claude --effort). 'default' omits the flag."
        },
        "symposium.codex.executable": {
          "type": "string",
          "default": "codex",
          "description": "Path to the Codex CLI executable."
        },
        "symposium.codex.model": {
          "type": "string",
          "default": "",
          "description": "Model passed to codex exec --model. Empty uses the CLI default."
        },
        "symposium.codex.reasoning": {
          "type": "string",
          "enum": [
            "default",
            "minimal",
            "low",
            "medium",
            "high"
          ],
          "default": "default",
          "description": "Default reasoning effort for Codex terminal sessions (codex -c model_reasoning_effort). 'default' omits it."
        },
        "symposium.copilot.executable": {
          "type": "string",
          "default": "copilot",
          "description": "Path to the GitHub Copilot CLI executable."
        },
        "symposium.copilot.model": {
          "type": "string",
          "default": "",
          "description": "Model passed to copilot --model. Empty uses the CLI default."
        },
        "symposium.copilot.reasoning": {
          "type": "string",
          "enum": [
            "default",
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "default": "default",
          "description": "Default reasoning effort for Copilot terminal sessions (copilot --reasoning-effort). 'default' omits it."
        },
        "symposium.chat.openIn": {
          "type": "string",
          "enum": [
            "editor",
            "sidebar"
          ],
          "default": "editor",
          "description": "Where sessions open: as a full editor panel (default, like the built-in chat sessions viewer) or in the Symposium sidebar Chat view."
        },
        "symposium.chat.sessionsSide": {
          "type": "string",
          "enum": [
            "auto",
            "left",
            "right"
          ],
          "default": "auto",
          "description": "Side of the sessions list inside the chat surface. 'auto' follows the dock side (sessions on the outer edge: right when docked right, left when docked left)."
        },
        "symposium.chat.defaultSendMode": {
          "type": "string",
          "enum": [
            "send",
            "queue",
            "steer"
          ],
          "enumDescriptions": [
            "Send now when idle; queued while a turn is running.",
            "Always wait for the current turn, then send (FIFO).",
            "Interrupt the running turn and send immediately."
          ],
          "default": "send",
          "description": "Default behavior of the composer send control. Overridable per session with the dropdown next to the send button."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.100.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0"
  }
}
